# Portfolio Suite Backend - Environment Variables Template
# Copy this file to .env and update with your actual values
# NEVER commit .env file with real secrets to version control

# ==============================================================================
# ENVIRONMENT CONFIGURATION
# ==============================================================================
ENVIRONMENT=development

# ==============================================================================
# SECURITY - CRITICAL
# ==============================================================================
# Secret key for JWT token signing (REQUIRED in production for HS256)
# Generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here_replace_in_production_generate_with_openssl_rand_hex_32

# JWT Algorithm - Choose one:
# - HS256: Symmetric (uses SECRET_KEY, faster, simpler)
# - RS256: Asymmetric (uses RSA keys, more secure for distributed systems)
ALGORITHM=HS256

# JWT Token Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# RSA Keys for RS256 (only needed if ALGORITHM=RS256)
# Generate keys with: python scripts/generate_rsa_keys.py
# Option 1: File paths (recommended)
# JWT_PRIVATE_KEY_PATH=/path/to/private_key.pem
# JWT_PUBLIC_KEY_PATH=/path/to/public_key.pem
#
# Option 2: Keys as environment variables (use \n for newlines)
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Debug mode (MUST be False in production)
DEBUG=True

# Allowed hosts (comma-separated, MUST NOT be * in production)
ALLOWED_HOSTS=*

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolioai
DATABASE_URL_DEVELOPMENT=postgresql://postgres:postgres@localhost:5432/portfolioai_dev
DATABASE_URL_TESTING=postgresql://postgres:postgres@localhost:5432/portfolioai_test

# Database Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=0
DB_POOL_TIMEOUT=30
DB_SSL_ENABLED=False
DB_SSL_MODE=prefer

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================
PROJECT_NAME=Portfolio API
VERSION=1.0.0
API_V1_STR=/api

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==============================================================================
# FILE STORAGE
# ==============================================================================
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx

# ==============================================================================
# SMTP / EMAIL CONFIGURATION
# ==============================================================================
SMTP_HOST=<SMTP_HOSTNAME>
SMTP_PORT=<SMTP_PORT>
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password_here
SMTP_TLS=True
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Portfolio API

# ==============================================================================
# SECURITY HEADERS
# ==============================================================================
HSTS_ENABLED=False
HSTS_MAX_AGE=31536000
CSP_ENABLED=True

# ==============================================================================
# RATE LIMITING & DDOS PROTECTION
# ==============================================================================
RATE_LIMIT_ENABLED=False
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
MAX_REQUEST_SIZE=10485760
REQUEST_TIMEOUT=30
AUTO_BLOCK_ENABLED=True
BLOCK_THRESHOLD_VIOLATIONS=10
BLOCK_DURATION=3600

# ==============================================================================
# LOGGING
# ==============================================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=text
LOG_SQL=False

# ==============================================================================
# SECURITY MONITORING & ALERTING
# ==============================================================================
SECURITY_EMAIL_ALERTS_ENABLED=False
SECURITY_ALERT_RECIPIENTS=security@example.com

# ==============================================================================
# MFA & ACCOUNT SECURITY
# ==============================================================================
MFA_ISSUER=Portfolio Suite
PASSWORD_RESET_EXPIRY_HOURS=2
EMAIL_VERIFICATION_EXPIRY_HOURS=24

# ==============================================================================
# BACKUP & DISASTER RECOVERY
# ==============================================================================
BACKUP_RETENTION_DAYS=30

# ==============================================================================
# FIELD-LEVEL ENCRYPTION (PII Protection)
# ==============================================================================
# Master encryption key for field-level encryption (CRITICAL - KEEP SECRET)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_MASTER_KEY=generate_with_command_above_in_production

# Salt for key derivation (generate random, keep consistent)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_SALT=generate_random_salt_in_production

# ==============================================================================
# AGENT CREDENTIAL ENCRYPTION (REQUIRED)
# ==============================================================================
# Passphrase used by pgcrypto to encrypt API keys stored in agent_credentials.
# REQUIRED — without this, the server cannot encrypt or decrypt any API key.
# Generate with: openssl rand -base64 32
AGENT_KMS_KEY=generate_with_openssl_rand_base64_32

# ==============================================================================
# AI PROVIDER KEYS (OPTIONAL after running migrate_credentials_to_db.py)
# ==============================================================================
# These variables are used as a FALLBACK when no DB credential is configured
# via the Agents admin module.
#
# After running `python scripts/migrate_credentials_to_db.py`, these values
# will be stored encrypted in the agent_credentials table and mapped through
# system_settings keys:
#   career.credential_id        → primary career provider
#   career.model                → model override for career tasks
#   career.fallback_credential_id → fallback career provider
#   embed.credential_id         → embedding provider
#
# You can then remove these env vars and manage keys from the Admin UI.

# Primary career AI provider (defaults to Anthropic if unset)
# CAREER_AI_PROVIDER=anthropic
# CAREER_AI_API_KEY=sk-ant-...
# CAREER_AI_MODEL=claude-haiku-4-5-20251001
# CAREER_AI_BASE_URL=

# Fallback career provider (used when primary hits rate-limit)
# CAREER_AI_FALLBACK_PROVIDER=openai
# CAREER_AI_FALLBACK_API_KEY=sk-...
# CAREER_AI_FALLBACK_MODEL=gpt-4o-mini
# CAREER_AI_FALLBACK_BASE_URL=

# Anthropic shorthand (used if CAREER_AI_API_KEY is not set)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI key used for embeddings (resolved from embed.credential_id system
# setting at startup; this env var is the last-resort fallback)
# OPENAI_API_KEY=sk-...

# Embedding provider / model (can also be set via system_settings in the UI)
# EMBED_PROVIDER=openai
# EMBED_MODEL=text-embedding-3-small
